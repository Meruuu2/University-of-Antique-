# Production Environment Configuration
# Copy this to .env.production and update values

APP_NAME="UA Facility Management"
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_URL=https://fms.uaniversity.edu

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=your-db-host
DB_PORT=3306
DB_DATABASE=ua_fms_prod
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# FMS Security Configuration
# Change these values for production deployment
FMS_ACCESS_TOKEN=PROD-ACCESS-2025-CHANGE-ME
FMS_LAUNCHER_SECRET=PROD-LAUNCHER-2025-CHANGE-ME
FMS_LOGIN_URL=https://fms.uaniversity.edu/fms-portal-entry

# Session & Cache
SESSION_DRIVER=file
CACHE_DRIVER=file

# Mail Configuration (for notifications)
MAIL_MAILER=smtp
MAIL_HOST=your-mail-host
MAIL_PORT=587
MAIL_USERNAME=your-mail-user
MAIL_PASSWORD=your-mail-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@uaniversity.edu
MAIL_FROM_NAME="${APP_NAME}"
